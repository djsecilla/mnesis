# mnesis environment — copy to `.env` and edit. `.env` is gitignored (never
# commit secrets). docker-compose loads it for both variable interpolation and
# the container environment.

# --- LLM ---------------------------------------------------------------------
# Provider: "anthropic" (default) or "local" (Ollama / OpenAI-compatible — runs
# inference on-host so sources never leave the trust boundary).
MNESIS_LLM_PROVIDER=anthropic

# Your Anthropic key for real extraction (provider=anthropic). Leave BLANK to run offline.
ANTHROPIC_API_KEY=

# Model id. For provider=anthropic, an Anthropic model. For provider=local, an
# Ollama tag you have pulled, e.g. "llama3.2:3b".
MNESIS_LLM_MODEL=claude-sonnet-4-6

# Local model server endpoint (used only when MNESIS_LLM_PROVIDER=local). Points
# at a server running on the HOST (your own Ollama / any OpenAI-compatible API);
# from inside the container the host is reached at host.docker.internal.
MNESIS_LLM_BASE_URL=http://host.docker.internal:11434

# Set to 1 for a fully offline, no-network demo (deterministic stub LLM).
# (For provider=anthropic, stub also auto-enables when ANTHROPIC_API_KEY is blank.)
MNESIS_LLM_STUB=1

# To run local-first inference instead (no Anthropic, sources stay on the box):
#   1. Run Ollama on the host:  ollama serve   (and:  ollama pull llama3.2:3b)
#   2. In this file set:
#        MNESIS_LLM_PROVIDER=local
#        MNESIS_LLM_MODEL=llama3.2:3b
#        MNESIS_LLM_STUB=0      (let the local model do the work)
#   3. docker compose up -d --force-recreate mnesis
# mnesis reaches the host Ollama via MNESIS_LLM_BASE_URL above — no Ollama
# container is run.

# Quality gate for filing synthesized answers back as digest pages.
MNESIS_FILEBACK_THRESHOLD=0.7

# --- MCP server (HTTP transport) --------------------------------------------
# HOST port to publish the server on (container always listens on 8080).
MNESIS_MCP_PORT=8080

# Bearer token required on every tool call. STRONGLY recommended in http mode —
# the endpoint can ingest and modify knowledge. Leave blank for an unauthenticated
# (privileged) endpoint; the server logs a warning when no token is set.
MNESIS_MCP_TOKEN=

# --- Web UI -----------------------------------------------------------------
# HOST port for the browser UI (the nginx container always listens on 80). The
# UI proxies /api to mnesis over the internal network; when MNESIS_MCP_TOKEN is
# set above, nginx injects it server-side so the browser never holds the token.
MNESIS_UI_PORT=3000

# Max bytes accepted by the ingestion upload endpoints (pasted text or file).
# Enforced by the backend; mnesis-ui mirrors it into nginx's client_max_body_size
# (plus headroom for the multipart envelope) so uploads pass through the proxy.
MNESIS_MAX_UPLOAD_BYTES=2000000

# --- Maintenance sidecar (profile: maintenance) -----------------------------
# Interval (seconds) between upkeep cycles (decay / graph-lint / rebuild-if-missing).
# Default 86400 (daily). Used only with `docker compose --profile maintenance up`.
MNESIS_MAINT_INTERVAL=86400
