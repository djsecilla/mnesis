# mnesis environment — copy to `.env` and edit. `.env` is gitignored (never
# commit secrets). docker-compose loads it for both variable interpolation and
# the container environment.

# --- LLM (SHARED by Mnesis core AND the LangGraph agents layer) --------------
# These MNESIS_LLM_* vars drive BOTH Mnesis's own extraction/synthesis and the
# agentic layer — one switch, no code change. Providers:
#   anthropic | local | openai | google | mistral | bedrock | ollama | openai_compatible
# "local" = an on-host OpenAI-compatible server (Ollama) — native httpx path, no
# extra deps. The broader providers go through the shared multi-LLM factory and
# need their extra installed (e.g. `pip install -e ".[agents-openai]"`).
MNESIS_LLM_PROVIDER=anthropic

# Your Anthropic key for real extraction (provider=anthropic). Leave BLANK to run offline.
ANTHROPIC_API_KEY=

# Generic API-key / temperature passthrough for the shared-factory providers
# (provider SDKs usually read their own env, e.g. OPENAI_API_KEY). Optional.
MNESIS_LLM_API_KEY=
MNESIS_LLM_TEMPERATURE=0

# Model id. For provider=anthropic, an Anthropic model. For provider=local, an
# Ollama tag you have pulled, e.g. "llama3.2:3b".
MNESIS_LLM_MODEL=claude-sonnet-4-6

# Local model server endpoint (used only when MNESIS_LLM_PROVIDER=local). Points
# at a server running on the HOST (your own Ollama / any OpenAI-compatible API);
# from inside the container the host is reached at host.docker.internal.
MNESIS_LLM_BASE_URL=http://host.docker.internal:11434

# Read timeout (seconds) for a single LLM completion. Local models on modest
# hardware can be slow on longer sources — raise this if ingest reports
# "llm_timeout". Default 300.
MNESIS_LLM_TIMEOUT=300

# Set to 1 for a fully offline, no-network demo (deterministic stub LLM).
# (For provider=anthropic, stub also auto-enables when ANTHROPIC_API_KEY is blank.)
MNESIS_LLM_STUB=1

# To run local-first inference instead (no Anthropic, sources stay on the box):
#   1. Run Ollama on the host:  ollama serve   (and:  ollama pull llama3.2:3b)
#   2. In this file set:
#        MNESIS_LLM_PROVIDER=local
#        MNESIS_LLM_MODEL=llama3.2:3b
#        MNESIS_LLM_STUB=0      (let the local model do the work)
#   3. docker compose up -d --force-recreate mnesis
# mnesis reaches the host Ollama via MNESIS_LLM_BASE_URL above — no Ollama
# container is run.

# Quality gate for filing synthesized answers back as digest pages.
MNESIS_FILEBACK_THRESHOLD=0.7

# --- Knowledge graph: predicate vocabulary ----------------------------------
# The relationship types ("predicates") the extractor may use to connect
# entities. Leave BLANK for the built-in default (13 predicates covering
# engineering + general knowledge). To customise, set a comma-separated list
# that REPLACES the default (entries are snake_cased automatically):
#   MNESIS_PREDICATES=uses,part_of,located_in,created,related_to
# `supersedes` and `contradicts` are always included (the graph emits them);
# keep `depends_on`/`uses` if you rely on impact analysis.
#
# Trade-offs of the list length (see CLAUDE.md §6):
#   - Too FEW  -> relationships have no valid predicate and are dropped, leaving
#     conceptually-connected entities as isolated nodes.
#   - Too MANY -> near-synonyms (created/founded/built) make the model pick
#     inconsistently, so the SAME real relationship gets different predicates
#     across pages and edges that should merge don't; the list also bloats every
#     extraction prompt (slower/costlier, esp. on local models).
#   Sweet spot: ~8-15 distinct, orthogonal predicates + one catch-all
#   (related_to). Prefer fewer broad predicates over many narrow synonyms.
# The value below spells out the full built-in default (editing it = customising):
MNESIS_PREDICATES=uses,depends_on,owns,caused,fixed,contradicts,supersedes,part_of,located_in,created,precedes,influences,related_to

# Predicates whose direction is not meaningful (A rel B == B rel A). A symmetric
# edge is stored once (reciprocal A->B / B->A assertions collapse into one),
# traversed from either endpoint, and drawn without a direction arrow. Replaces
# the default when set; intersected with MNESIS_PREDICATES; empty = none.
MNESIS_SYMMETRIC_PREDICATES=contradicts,related_to

# The entity types ("type" in a type:value ref). Leave BLANK for the built-in
# default (person, project, library, concept, file, decision). To customise, set
# a comma-separated list that REPLACES the default (snake_cased automatically):
#   MNESIS_ENTITY_TYPES=person,org,place,event,concept
# "page" is reserved (structural page nodes) and is dropped if listed. Same
# length trade-offs as predicates apply. NOTE: the Web UI assigns distinct
# colours only to the built-in six types; custom types render in the fallback
# colour unless you add matching --entity-<type> CSS vars (a UI rebuild).
MNESIS_ENTITY_TYPES=person,organization,project,library,concept,file,decision

# --- MCP server (HTTP transport) --------------------------------------------
# HOST port to publish the server on (container always listens on 8080).
MNESIS_MCP_PORT=8080

# Bearer token required on every tool call. STRONGLY recommended in http mode —
# the endpoint can ingest and modify knowledge. Leave blank for an unauthenticated
# (privileged) endpoint; the server logs a warning when no token is set.
MNESIS_MCP_TOKEN=

# --- Web UI -----------------------------------------------------------------
# HOST port for the browser UI (the nginx container always listens on 80). The
# UI proxies /api to mnesis over the internal network; when MNESIS_MCP_TOKEN is
# set above, nginx injects it server-side so the browser never holds the token.
MNESIS_UI_PORT=3000

# Max bytes accepted by the ingestion upload endpoints (pasted text or file).
# Enforced by the backend; mnesis-ui mirrors it into nginx's client_max_body_size
# (plus headroom for the multipart envelope) so uploads pass through the proxy.
MNESIS_MAX_UPLOAD_BYTES=2000000

# --- Maintenance: the dream-cycle agent (profile: agents) -------------------
# Periodic maintenance is owned by the scheduled dream-cycle MaintenanceAgent in
# the mnesis-agents-runtime service (the old `--profile maintenance` sidecar is
# RETIRED — there is exactly ONE scheduler, no double-run). Bring it up with
# `docker compose --profile agents up -d`. The cycle runs over MCP: it auto-applies
# safe hygiene (decay + safe graph-lint fixes) and queues contradiction/dedup
# proposals for human review (never auto-resolves/merges).
#
# Register the scheduled cycle in the runtime (the single periodic-maintenance
# owner). Set 0 for an idle runtime.
MNESIS_AGENTS_DREAM_ENABLED=1
# Cadence (seconds). The bundled scheduler is interval-based; default ~daily
# (nightly). Set lower for a smoke test. A precise cron (MNESIS_AGENTS_DREAM_CRON,
# default "0 3 * * *") needs the APScheduler extra.
MNESIS_AGENTS_DREAM_INTERVAL_SECONDS=86400
# Meta-memory: file a concise digest of each cycle back into Mnesis (redaction
# still applies). OFF unless set to 1.
# MNESIS_AGENTS_CRYSTALLIZE=1

# --- Runtime agent (profile: agent) -----------------------------------------
# The ingest-daemon (and the one-off research/assistant runs) reach mnesis ONLY
# over the MCP endpoint on the internal compose network. The agent presents the
# MNESIS_MCP_TOKEN above; it must match the server's token. Mnesis governs every
# write server-side — the agent cannot bypass redaction or contradiction review.
#
# Host directory the ingest-daemon watches; drop .txt/.md files here to ingest
# them. Mounted read-only into the container at /watch.
MNESIS_AGENT_WATCH_DIR=./agent_watch

# Seconds between watch-directory scans.
MNESIS_AGENT_POLL_INTERVAL=5

# Override the MCP URL the agent connects to (default http://mnesis:8080/mcp on
# the internal network). Set this only to point at an external mnesis.
# MNESIS_AGENT_MCP_URL=http://mnesis:8080/mcp

# Opt-in in-process local tools (e.g. web_search). OFF unless set to 1; even
# then, only the research profile may use them. A plain run has only Mnesis tools.
# MNESIS_AGENT_ENABLE_LOCAL_TOOLS=1

# Fully-local, on-prem agent stack (no external inference): set MNESIS_LLM_PROVIDER=local
# (and MNESIS_LLM_STUB=0, MNESIS_LLM_MODEL=<an Ollama tag>) above. Both mnesis and
# the agent then target your host Ollama via MNESIS_LLM_BASE_URL; nothing leaves
# the machine. The ingest-daemon itself calls no LLM (extraction runs in mnesis);
# only `agent research` / `agent assistant` use the provider.
#   docker compose --profile agent up -d
