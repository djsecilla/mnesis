# Keep the build context small and free of host-only / regenerable artifacts.
.git
.gitignore
.venv
**/__pycache__
*.pyc
*.pyo

# Rebuildable caches (search index, graph, durable state live under the volume).
wiki/.index
mnesis/.index

# The wiki data and host scratch — not part of the image.
wiki/
scripts/
tests/
.pytest_cache

# Agent host scratch (watch inbox + run audit) — mounted at runtime, never baked.
agent_watch/
agent_runs/

# Packaging / docs noise.
*.egg-info
build/
dist/
*.docx
mnesis_*_Prompts.md
LLM_Wiki_*

# secrets / compose (not needed in the image)
.env
docker-compose*.yml
